{
  "name": "@kylealanjeffrey/badge",
  "version": "0.0.2",
  "description": "A \"built by Kyle\" badge component linking to kylejeffrey.com",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  },
  "keywords": [
    "react",
    "badge",
    "component"
  ],
  "author": "Kyle Jeffrey",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/kylealanjeffrey/badge"
  },
  "sideEffects": false
}
